pkgbase = expressvpn-tray-icon-fix
	pkgdesc = Improved ExpressVPN tray icons with live light/dark theme switching
	pkgver = 0.1.0
	pkgrel = 1
	url = https://github.com/seanyates76/expressvpn-tray-icon-fix
	install = expressvpn-tray-icon-fix.install
	arch = x86_64
	license = MIT
	makedepends = imagemagick
