#!/usr/bin/env bash
set -euo pipefail

runtime_root="/usr/lib/expressvpn-tray-icon-fix"
app_path="/opt/expressvpn/bin/expressvpn-client"
integrate_helper_path="$runtime_root/bin/expressvpn-tray-icon-fix-integrate"
launcher_argv0="/usr/bin/expressvpn-tray-icon-fix"
config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
cache_home="${XDG_CACHE_HOME:-$HOME/.cache}"
settings_path="$config_home/expressvpn/clientsettings.json"
style_config_path="$config_home/expressvpn-tray-icon-fix/style"
log_path="$cache_home/expressvpn-tray-icon-fix/launcher.log"

print_usage() {
  cat <<'EOF'
Usage:
  expressvpn-tray-icon-fix [options] [-- <expressvpn args>]

Options:
  --style STYLE        Persist STYLE and launch. STYLE: colored | monochrome
  --set-style STYLE    Persist STYLE and exit.
  --print-style        Print the effective persisted/default style and exit.
  --repair-integration Recreate the managed ExpressVPN launcher integration.
  --disable-integration
                       Remove the managed ExpressVPN launcher integration.
  --integration-status Print current integration status.
  --foreground         Launch in the current terminal instead of backgrounding.
  -h, --help           Show this help.
EOF
}

write_style_config() {
  local style="$1"
  mkdir -p "$(dirname "$style_config_path")"
  printf '%s\n' "$style" > "$style_config_path"
}

detect_system_icon_set() {
  local system_theme_path path
  system_theme_path="${EXPRESSVPN_TRAY_SYSTEM_THEME_FILE:-}"

  for path in \
    "$system_theme_path" \
    "$config_home/xsettingsd/xsettingsd.conf" \
    "$config_home/kdeglobals" \
    "$config_home/gtk-3.0/settings.ini" \
    "$config_home/gtk-4.0/settings.ini"; do
    [[ -n "$path" && -f "$path" ]] || continue

    if grep -qiE 'gtk-application-prefer-dark-theme *= *true|^(Net/ThemeName|Net/IconThemeName) .*dark|^gtk-icon-theme-name=.*dark|^(gtk-theme-name|LookAndFeelPackage|ColorScheme)=.*dark' "$path"; then
      printf 'dark\n'
      return 0
    fi

    if grep -qiE 'gtk-application-prefer-dark-theme *= *false|^(Net/ThemeName|Net/IconThemeName) ".*breeze"|^gtk-icon-theme-name=breeze$|^(LookAndFeelPackage|ColorScheme)=.*light' "$path"; then
      printf 'light\n'
      return 0
    fi
  done

  printf 'light\n'
}

select_style() {
  local raw
  raw="${EXPRESSVPN_TRAY_ICON_FIX_STYLE:-}"
  if [[ -z "$raw" && -f "$style_config_path" ]]; then
    raw="$(<"$style_config_path")"
  fi

  case "${raw,,}" in
    monochrome)
      printf 'monochrome\n'
      ;;
    *)
      printf 'colored\n'
      ;;
  esac
}

run_integration_action() {
  local action="$1"

  if [[ ! -x "$integrate_helper_path" ]]; then
    echo "Missing integration helper: $integrate_helper_path" >&2
    exit 1
  fi

  case "$action" in
    repair)
      exec "$integrate_helper_path" enable
      ;;
    disable)
      exec "$integrate_helper_path" disable
      ;;
    status)
      exec "$integrate_helper_path" status
      ;;
    *)
      echo "Unknown integration action: $action" >&2
      exit 1
      ;;
  esac
}

list_matching_client_pids() {
  local mode="$1"
  local pid args

  while read -r pid args; do
    [[ -n "${pid:-}" && "$pid" != "$$" ]] || continue

    case "$mode" in
      wrapped)
        case "$args" in
          "$launcher_argv0"*)
            printf '%s\n' "$pid"
            ;;
        esac
        ;;
      raw)
        case "$args" in
          "$app_path"*)
            printf '%s\n' "$pid"
            ;;
        esac
        ;;
    esac
  done < <(ps -u "$(id -u)" -o pid= -o args=)
}

wait_for_pids_to_exit() {
  local pid
  local countdown=50

  while ((countdown > 0)); do
    local any_alive=0
    for pid in "$@"; do
      if kill -0 "$pid" >/dev/null 2>&1; then
        any_alive=1
        break
      fi
    done

    if [[ "$any_alive" -eq 0 ]]; then
      return 0
    fi

    sleep 0.1
    ((countdown--))
  done

  return 1
}

effective_app_args=()

build_effective_app_args() {
  effective_app_args=("${passthrough_args[@]}")
  if [[ "$quiet" -eq 1 ]]; then
    effective_app_args=(--quiet "${effective_app_args[@]}")
  fi
}

launch_app_foreground() {
  exec -a "$launcher_argv0" env -u SESSION_MANAGER XDG_SESSION_TYPE=X11 "$app_path" "${effective_app_args[@]}"
}

launch_app_background() {
  mkdir -p "$(dirname "$log_path")"
  nohup bash -lc 'exec -a "$0" env -u SESSION_MANAGER XDG_SESSION_TYPE=X11 "$1" "${@:2}"' \
    "$launcher_argv0" "$app_path" "${effective_app_args[@]}" >"$log_path" 2>&1 &
  if [[ "$quiet" -eq 0 ]]; then
    printf 'Launched ExpressVPN Tray Icon Fix in background.\n'
    printf 'Log: %s\n' "$log_path"
  fi
}

tray_host_ready() {
  if command -v busctl >/dev/null 2>&1; then
    if busctl --user --list 2>/dev/null | grep -q 'StatusNotifierWatcher'; then
      return 0
    fi
  fi

  pgrep -u "$(id -u)" -x plasmashell >/dev/null 2>&1 &&
    pgrep -u "$(id -u)" -f 'xembedsniproxy|snixembed' >/dev/null 2>&1
}

wait_for_tray_host() {
  local attempts=8

  sleep 1

  while ((attempts > 0)); do
    if tray_host_ready; then
      return 0
    fi

    sleep 0.25
    ((attempts--))
  done

  return 1
}

prepare_autostart_launch() {
  local raw_pids=()
  local wrapped_pids=()

  wait_for_tray_host || true

  mapfile -t wrapped_pids < <(list_matching_client_pids wrapped)
  if ((${#wrapped_pids[@]} > 0)); then
    exit 0
  fi

  mapfile -t raw_pids < <(list_matching_client_pids raw)
  if ((${#raw_pids[@]} == 0)); then
    return 0
  fi

  kill "${raw_pids[@]}" >/dev/null 2>&1 || true
  if ! wait_for_pids_to_exit "${raw_pids[@]}"; then
    exit 0
  fi
}

foreground=0
quiet=0
persist_only=0
autostart=0
style_override=""
integration_action=""
passthrough_args=()

while (($#)); do
  case "$1" in
    --style)
      shift
      [[ $# -gt 0 ]] || { echo "Missing value for --style" >&2; exit 1; }
      style_override="$1"
      ;;
    --style=*)
      style_override="${1#*=}"
      ;;
    --set-style)
      persist_only=1
      shift
      [[ $# -gt 0 ]] || { echo "Missing value for --set-style" >&2; exit 1; }
      style_override="$1"
      ;;
    --set-style=*)
      persist_only=1
      style_override="${1#*=}"
      ;;
    --print-style)
      select_style
      exit 0
      ;;
    --repair-integration|--reinstall-integration)
      integration_action="repair"
      ;;
    --disable-integration)
      integration_action="disable"
      ;;
    --integration-status)
      integration_action="status"
      ;;
    --foreground)
      foreground=1
      ;;
    --quiet)
      quiet=1
      ;;
    --autostart)
      autostart=1
      quiet=1
      ;;
    -h|--help)
      print_usage
      exit 0
      ;;
    --)
      shift
      passthrough_args+=("$@")
      break
      ;;
    *)
      passthrough_args+=("$1")
      ;;
  esac
  shift || true
done

if [[ -n "$style_override" ]]; then
  case "${style_override,,}" in
    colored|monochrome)
      write_style_config "${style_override,,}"
      ;;
    *)
      echo "Invalid style: $style_override" >&2
      echo "Expected: colored or monochrome" >&2
      exit 1
      ;;
  esac
fi

if [[ "$persist_only" -eq 1 ]]; then
  exit 0
fi

if [[ -n "$integration_action" ]]; then
  run_integration_action "$integration_action"
fi

style="$(select_style)"
style_root="$runtime_root/styles/$style"
preload_path="$runtime_root/lib/libexpressvpn-tray-override.so"
rcc_path="$style_root/override.rcc"
rcc_dark_path="$style_root/override-dark.rcc"
rcc_light_path="$style_root/override-light.rcc"
asset_root="$style_root/assets"

for required in \
  "$app_path" \
  "$preload_path" \
  "$rcc_path" \
  "$rcc_dark_path" \
  "$rcc_light_path"; do
  if [[ ! -e "$required" ]]; then
    echo "Missing required file: $required" >&2
    exit 1
  fi
done

system_icon_set="$(detect_system_icon_set)"
if [[ -f "$settings_path" ]]; then
  tmp_settings="$(mktemp)"
  sed -E "s/\"iconSet\":\"[^\"]+\"/\"iconSet\":\"$system_icon_set\"/" "$settings_path" > "$tmp_settings"
  mv "$tmp_settings" "$settings_path"
fi

app_size="$(stat -c '%s' "$app_path")"
app_mtime="$(stat -c '%Y' "$app_path")"

export TRAY_OVERRIDE_RCC="$rcc_path"
export TRAY_OVERRIDE_RCC_DARK="$rcc_dark_path"
export TRAY_OVERRIDE_RCC_LIGHT="$rcc_light_path"
export TRAY_OVERRIDE_ASSET_ROOT="$asset_root"
export EXPRESSVPN_TRAY_SYNC_ICONSET=1
export EXPRESSVPN_TRAY_SYNC_APP_SIZE="$app_size"
export EXPRESSVPN_TRAY_SYNC_APP_MTIME="$app_mtime"
if [[ -n "${EXPRESSVPN_TRAY_SYSTEM_THEME_FILE:-}" ]]; then
  export EXPRESSVPN_TRAY_SYSTEM_THEME_FILE
fi
export LD_PRELOAD="$preload_path${LD_PRELOAD:+:${LD_PRELOAD}}"

if [[ "$autostart" -eq 1 ]]; then
  prepare_autostart_launch
fi

build_effective_app_args

if [[ "$foreground" -eq 1 || ! -t 1 ]]; then
  launch_app_foreground
fi

launch_app_background
